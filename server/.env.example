PORT=3001
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your_password
MYSQL_DATABASE=aegis_auth

# JWT for temporary step-up token (password ok → TOTP pending)
JWT_TEMP_SECRET=change-me-temp-min-32-chars-long!!
# Signing session cookie payload (optional; we use opaque DB ids)
JWT_SESSION_SECRET=change-me-session-min-32-chars!!

# CORS: comma-separated origins (Vite default http://localhost:5173)
CORS_ORIGINS=http://localhost:5173

# Session lifetime (hours)
SESSION_HOURS=24
